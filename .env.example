DATABASE_URL=
# Optional: required for `npx prisma migrate dev` (it creates/drops a shadow DB).
# For hosted DBs, point this at a separate, disposable database you control.
SHADOW_DATABASE_URL=

AUTH_SECRET=
NEXTAUTH_URL=

# Optional: keeps Prisma caches inside the repo (useful on some deploy targets).
PRISMA_USER_HOME=./.prisma
